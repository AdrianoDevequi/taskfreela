generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              user    @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Account_userId_fkey")

  @@unique([provider, providerAccountId], map: "Account_provider_providerAccountId_key")
  @@index([userId], map: "Account_userId_fkey")
}

model workspace {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  users        user[]
  tasks        task[]
  reminders    reminder[]
  integrations integration[]
  projects     project[]

  @@map("Workspace")
}

model integration {
  id           String     @id @default(uuid())
  provider     String
  accessToken  String     @db.Text
  refreshToken String?    @db.Text
  expiresAt    BigInt?
  calendarId   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  accountEmail String?
  userId       String?
  workspaceId  String?
  user         user?      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Integration_userId_fkey")
  workspace    workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade, map: "Integration_workspaceId_fkey")

  @@index([userId], map: "Integration_userId_idx")
  @@index([workspaceId], map: "Integration_workspaceId_idx")
}

model reminder {
  id          String     @id @default(uuid())
  content     String
  isCompleted Boolean    @default(false)
  createdAt   DateTime   @default(now())
  userId      String?
  workspaceId String?
  user        user?      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Reminder_userId_fkey")
  workspace   workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade, map: "Reminder_workspaceId_fkey")

  @@index([userId], map: "Reminder_userId_idx")
  @@index([workspaceId], map: "Reminder_workspaceId_idx")
}

model session {
  id           String   @id @default(uuid())
  sessionToken String   @unique(map: "Session_sessionToken_key")
  userId       String
  expires      DateTime
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Session_userId_fkey")

  @@index([userId], map: "Session_userId_fkey")
}

model task {
  id            Int        @id @default(autoincrement())
  title         String
  description   String?    @db.Text
  dueDate       DateTime
  status        String     @default("TODO")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  estimatedTime String?
  userId        String?
  workspaceId   String?
  assignedToId  String?
  projectId     String?
  user          user?      @relation("TaskCreator", fields: [userId], references: [id], onDelete: Cascade, map: "Task_userId_fkey")
  assignedTo    user?      @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull, map: "Task_assignedToId_fkey")
  workspace     workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade, map: "Task_workspaceId_fkey")
  project       project?   @relation(fields: [projectId], references: [id], onDelete: SetNull, map: "Task_projectId_fkey")

  @@index([userId], map: "Task_userId_idx")
  @@index([workspaceId], map: "Task_workspaceId_idx")
  @@index([assignedToId], map: "Task_assignedToId_idx")
  @@index([projectId], map: "Task_projectId_idx")
}

model user {
  id            String        @id @default(uuid())
  name          String?
  email         String?       @unique(map: "User_email_key")
  emailVerified DateTime?
  image         String?
  password      String?
  role          String        @default("EMPLOYEE")
  workspaceId   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  account       account[]
  integration   integration[]
  reminder      reminder[]
  session       session[]
  createdTasks  task[]        @relation("TaskCreator")
  assignedTasks task[]        @relation("TaskAssignee")
  workspace     workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull, map: "User_workspaceId_fkey")

  @@index([workspaceId], map: "User_workspaceId_idx")
}

model verificationtoken {
  identifier String
  token      String   @unique(map: "VerificationToken_token_key")
  expires    DateTime

  @@unique([identifier, token], map: "VerificationToken_identifier_token_key")
}

model Settings {
  id                Int    @id @default(1)
  apiUrl            String @default("")
  apiKey            String @default("")
  instanceName      String @default("")
  notificationPhone String @default("")

  @@map("settings")
}

model project {
  id          String     @id @default(uuid())
  name        String
  description String?    @db.Text
  status      String     @default("ACTIVE")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  workspaceId String
  workspace   workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade, map: "Project_workspaceId_fkey")
  tasks       task[]

  @@index([workspaceId], map: "Project_workspaceId_idx")
  @@map("Project")
}
